{
  "name": "@formegifts/mcp",
  "version": "0.0.0",
  "description": "MCP server for forme.gifts wishlist app",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "forme-mcp": "./dist/bin.js"
  },
  "main": "./dist/bin.js",
  "exports": {
    ".": "./dist/bin.js"
  },
  "homepage": "https://forme.gifts/mcp",
  "bugs": {
    "email": "feedback@forme.gifts"
  },
  "scripts": {
    "build": "tsup && chmod +x dist/bin.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.104.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^24",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "zod": "^4.3.6"
  }
}
